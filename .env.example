# ── Banco de dados (Neon PostgreSQL) ─────────────────────────────────────────
# Copie a connection string do painel do Neon:
# Settings → Connection String → selecione "Pooled connection"
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Autenticação JWT ──────────────────────────────────────────────────────────
# Gere um segredo forte, por exemplo:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque_por_um_segredo_longo_e_aleatorio

# ── E-mail (Gmail SMTP) ───────────────────────────────────────────────────────
# 1. Ative a verificação em 2 etapas na sua conta Google
# 2. Crie uma "Senha de app" em: myaccount.google.com/apppasswords
#    (categoria: Mail / dispositivo: Other)
# 3. Cole a senha de 16 caracteres em GMAIL_PASS (sem espaços)
GMAIL_USER=seu_email@gmail.com
GMAIL_PASS=abcd efgh ijkl mnop

# ── Usuário admin inicial (criado pelo seed) ──────────────────────────────────
ADMIN_EMAIL=admin@pesportes.ia.br
ADMIN_PASSWORD=Admin@2025!

# ── URLs ─────────────────────────────────────────────────────────────────────
# URL pública do frontend (usada nos e-mails de recuperação de senha)
FRONTEND_URL=https://pesportes.ia.br

# ── Porta local (dev) ────────────────────────────────────────────────────────
PORT=3000
